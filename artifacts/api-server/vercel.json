{
  "version": 2,
  "installCommand": "echo 'dist pre-built, skipping install'",
  "buildCommand": "echo 'dist pre-built, skipping build'",
  "builds": [
    {
      "src": "dist/vercel.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/vercel.mjs"
    }
  ]
}
